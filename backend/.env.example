# Comma-separated browser origins allowed to call the API (required for deployed Next.js → GraphQL).
# Example: https://trailintel.vercel.app,https://www.example.com
# CORS_ALLOW_ORIGINS=

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/trailintel
REDIS_URL=redis://localhost:6379/0
APP_ENV=development
USE_IN_MEMORY_REPOSITORY=false
# GraphQL submitReport / upvoteReport (fixed window per client IP; Redis-backed when available)
RATE_LIMIT_REPORTS_ENABLED=true
RATE_LIMIT_SUBMIT_MAX_PER_WINDOW=20
RATE_LIMIT_UPVOTE_MAX_PER_WINDOW=60
RATE_LIMIT_WINDOW_SECONDS=3600
ALLOW_PUBLIC_REPORT_SUBMISSION=false
HAZARD_EXPORT_PATH=backend/data/external_hazards.json
REVIEW_EXPORT_PATH=backend/data/external_reviews.json
# Optional committed real-source snapshot loaded when Postgres is unavailable (unset = backend/data/in_memory_fallback_snapshot.json)
# IN_MEMORY_FALLBACK_SNAPSHOT_PATH=
# Used by backend/scripts/rebuild_real_data.py (optional; defaults to DEMO_KEY).
NPS_API_KEY=DEMO_KEY
